{
  "schemaURL": "https://openlineage.io/spec/facets/1-2-0/ColumnLineageDatasetFacet.json",
  "_comment": "Curated multi-step trace produced by the SAS lineage tool. One section per output dataset. Each inputField's transformations carry both DIRECT contributions (shape the value) and INDIRECT contributions (shape which rows contribute: filter, join key, group-by key).",
  "datasets": {
    "mart.sales_monthly": {
      "fields": {
        "net_revenue": {
          "inputFields": [
            {
              "namespace": "sas",
              "name": "mart.orders_enriched",
              "field": "net_amount",
              "transformations": [
                {
                  "type": "DIRECT",
                  "subtype": "AGGREGATION",
                  "description": "sum(net_amount) as net_revenue",
                  "masking": false
                }
              ]
            },
            {
              "namespace": "sas",
              "name": "mart.orders_enriched",
              "field": "order_date",
              "transformations": [
                {
                  "type": "INDIRECT",
                  "subtype": "GROUP_BY",
                  "description": "put(order_date, yymmn6.) as month_id — grouping key, controls which rows aggregate together",
                  "masking": false
                }
              ]
            },
            {
              "namespace": "sas",
              "name": "mart.orders_enriched",
              "field": "country_code",
              "transformations": [
                {
                  "type": "INDIRECT",
                  "subtype": "GROUP_BY",
                  "description": "group by country_code",
                  "masking": false
                }
              ]
            },
            {
              "namespace": "sas",
              "name": "mart.orders_enriched",
              "field": "customer_segment",
              "transformations": [
                {
                  "type": "INDIRECT",
                  "subtype": "GROUP_BY",
                  "description": "group by customer_segment",
                  "masking": false
                }
              ]
            }
          ]
        }
      }
    },

    "mart.orders_enriched": {
      "fields": {
        "net_amount": {
          "inputFields": [
            {
              "namespace": "sas",
              "name": "stg.orders_clean",
              "field": "net_amount",
              "transformations": [
                {
                  "type": "DIRECT",
                  "subtype": "IDENTITY",
                  "description": "select o.* — passthrough from stg.orders_clean",
                  "masking": false
                }
              ]
            },
            {
              "namespace": "sas",
              "name": "stg.orders_clean",
              "field": "customer_id",
              "transformations": [
                {
                  "type": "INDIRECT",
                  "subtype": "JOIN",
                  "description": "left join key — o.customer_id = c.customer_id (and = s.customer_id)",
                  "masking": false
                }
              ]
            },
            {
              "namespace": "sas",
              "name": "stg.customers",
              "field": "customer_id",
              "transformations": [
                {
                  "type": "INDIRECT",
                  "subtype": "JOIN",
                  "description": "left join key — c.customer_id",
                  "masking": false
                }
              ]
            },
            {
              "namespace": "sas",
              "name": "stg.customer_segments",
              "field": "customer_id",
              "transformations": [
                {
                  "type": "INDIRECT",
                  "subtype": "JOIN",
                  "description": "left join key — s.customer_id",
                  "masking": false
                }
              ]
            }
          ]
        }
      }
    },

    "stg.orders_clean": {
      "fields": {
        "net_amount": {
          "inputFields": [
            {
              "namespace": "sas",
              "name": "raw.orders",
              "field": "gross_amt",
              "transformations": [
                {
                  "type": "DIRECT",
                  "subtype": "TRANSFORMATION",
                  "description": "(o.gross_amt - o.discount_amt) as net_amount",
                  "masking": false
                }
              ]
            },
            {
              "namespace": "sas",
              "name": "raw.orders",
              "field": "discount_amt",
              "transformations": [
                {
                  "type": "DIRECT",
                  "subtype": "TRANSFORMATION",
                  "description": "(o.gross_amt - o.discount_amt) as net_amount",
                  "masking": false
                }
              ]
            },
            {
              "namespace": "sas",
              "name": "raw.orders",
              "field": "order_status",
              "transformations": [
                {
                  "type": "INDIRECT",
                  "subtype": "FILTER",
                  "description": "where o.order_status not in ('CANCELLED', 'REJECTED')",
                  "masking": false
                }
              ]
            }
          ]
        }
      }
    }
  }
}
